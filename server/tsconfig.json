{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist-server",
    "rootDir": "..",
    "baseUrl": ".."
  },
  "include": ["*.ts", "../functions/**/*.ts"],
  "exclude": ["node_modules", "dist-server"]
}
